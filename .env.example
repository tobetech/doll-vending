# Supabase (จาก Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# URL ฐานของแอป (ใช้กับลิงก์ / fallback webhook Ksher)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Ksher C-scan-B — เติมเงิน PromptPay (ดู docs/TOPUP_MACHINE_INTEGRATION.md)
# KSHER_HOST=https://api.ksher.net
# KSHER_TOKEN=
# URL เต็มที่ลงทะเบียนใน Ksher dashboard ต้องตรงกับที่ใช้ verify ลายเซ็น
# KSHER_WEBHOOK_URL=https://your-domain.com/api/webhook/ksher
# ถ้าให้ Ksher ยิง webhook ไป n8n ก่อน แล้ว n8n ส่งต่อมาที่แอป — ตั้ง KSHER_WEBHOOK_URL = URL webhook ของ n8n (ต้องตรงที่ลงทะเบียนใน Ksher)

# ตู้เติมเงิน — ถ้าตั้งค่าแล้ว ต้องส่ง Authorization: Bearer <ค่าเดียวกัน> หรือ X-Vending-Topup-Secret เมื่อเรียก /api/webhook/vending-topup-scan-timeout
# VENDING_TOPUP_MACHINE_SECRET=
